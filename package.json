{
  "name": "home-basket",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web && node ./scripts/prepare-web-dist.js",
    "deploy:web": "npm run build:web && firebase deploy --only hosting",
    "mobile:preflight": "npm run typecheck && npm run lint",
    "mobile:android:preview": "npx eas-cli build --platform android --profile preview",
    "mobile:android:production": "npx eas-cli build --platform android --profile production",
    "mobile:android:submit:production": "npx eas-cli submit --platform android --profile production",
    "mobile:ios:device": "npx eas-cli device:create",
    "mobile:ios:preview": "npx eas-cli build --platform ios --profile preview",
    "mobile:ios:production": "npx eas-cli build --platform ios --profile production",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "expo": "~55.0.9",
    "expo-build-properties": "~55.0.11",
    "expo-constants": "~55.0.9",
    "expo-device": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-image-picker": "~55.0.14",
    "expo-linking": "~55.0.9",
    "expo-notifications": "~55.0.16",
    "expo-router": "~55.0.8",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.11",
    "expo-web-browser": "~55.0.10",
    "firebase": "^12.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-google-mobile-ads": "^16.3.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "typescript": "~5.9.2",
    "vitest": "^3.2.0"
  },
  "private": true
}
