{
  "expo": {
    "name": "Home Basket",
    "slug": "home-basket",
    "version": "1.0.0",
    "description": "A shared household shopping and purchase tracker for Android, iOS, and web.",
    "orientation": "portrait",
    "icon": "./assets/brand/homebasket_appicon.png",
    "scheme": "homebasket",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/brand/homebasket_appicon.png",
      "bundleIdentifier": "com.transcripe.homebasket",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.transcripe.homebasket",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#1A4731",
        "foregroundImage": "./assets/brand/homebasket_appicon.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/brand/homebasket_appicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Home Basket to open your photo library so you can attach receipt images to purchases."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1A4731",
          "android": {
            "image": "./assets/brand/homebasket_reversed.png",
            "imageWidth": 220
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5e5f1c9d-c715-442c-bf0b-758c135c7558"
      }
    },
    "owner": "transcripe"
  }
}
